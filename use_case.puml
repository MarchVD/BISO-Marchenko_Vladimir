@startuml use_case_diagram
left to right direction
skinparam actorStyle awesome

actor "Продавец" as Seller
actor "Покупатель" as Buyer
actor "Администратор" as Admin

rectangle "Система" {
    usecase "Регистрация" as Reg
    usecase "Вход в систему" as Login
    usecase "Публикация товара" as Publish
    usecase "Просмотр каталога" as Browse
    usecase "Составление заказа" as MakeOrder
    usecase "Оплата заказа" as Pay
    usecase "Сбор заказа" as Pack
    usecase "Управление пользователями" as ManageUsers
}

' Связи покупателя
Buyer --> Login
Buyer --> Browse
Buyer --> MakeOrder

' Связи продавца
Seller --> Login
Seller --> Publish
Seller --> Pack

' Связи администратора
Admin --> Login
Admin --> ManageUsers

' Отношения между use cases
Login ..> Reg : <<extend>>
MakeOrder ..> Pay : <<include>>

@enduml
